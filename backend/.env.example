# GiftByte backend example configuration.
#
# Copy this file to ".env" in the backend directory and fill values.
# IMPORTANT: save .env as UTF-8 (especially on Windows) and NEVER commit the real .env.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/giftbyte

# JWT config (use a long random value in real deployments)
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

